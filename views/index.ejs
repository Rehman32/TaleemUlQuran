<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <!-- Hero Section -->
    <section class="hero" id="hero" aria-label="Welcome">
      <div class="hero__inner">
        <div class="hero__content">
          <span class="hero__label">🌟 Trusted by Families Worldwide</span>
          <h1 class="hero__title">
            Embark on an <span>Enriching</span> Quranic Journey
          </h1>
          <p class="hero__text">
            Explore tailored Quranic and Islamic studies with Taleem Ul Quran Online Academy. Expert male & female tutors, flexible timings, personalized one-on-one sessions.
          </p>
          <div class="hero__actions">
            <a href="/register" class="btn btn--accent btn--lg">Start Free Trial</a>
            <a href="/courses" class="btn btn--white btn--lg">Explore Courses</a>
          </div>
        </div>

        <div class="hero__hadith fade-in">
          <p class="hero__hadith-label">قَالَ النَّبِيُّ صلى الله عليه وسلم</p>
          <p class="hero__hadith-arabic">إِنَّ أَفْضَلَكُمْ مَنْ تَعَلَّمَ الْقُرْآنَ وَعَلَّمَهُ</p>
          <p class="hero__hadith-translation">"The best amongst you is the one who learns the Qur'an and teaches it."</p>
          <p class="hero__hadith-source">— Sahih Al-Bukhari</p>
        </div>
      </div>
    </section>

    <!-- Welcome Section -->
    <section class="section" aria-label="About" id="about-preview">
      <div class="container">
        <div class="welcome">
          <div class="welcome__image fade-in">
            <img src="/images/pics/little_boy.jpg" alt="Young student learning Quran online" width="600" height="450" loading="lazy">
          </div>
          <div class="fade-in">
            <span class="section__label">Welcome to Our Academy</span>
            <h2 class="welcome__title">Your Path to Quranic Excellence</h2>
            <p class="welcome__text">
              Taleem Ul Quran Online Quran Academy is an international platform exclusively designed to help Muslim men, women, boys, and girls learn the Quran online. Our dedicated male and female tutors ensure a comfortable and supportive learning environment tailored to each student's needs.
            </p>
            <p class="welcome__text">
              We offer flexible online Quran classes across Pakistan, USA, UK, Canada, Australia, and beyond — allowing students to learn at their own pace from the comfort of home.
            </p>
            <a href="/about" class="btn btn--primary">Learn More About Us</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Courses Section -->
    <section class="section section--alt" aria-label="Our Courses" id="courses">
      <div class="container">
        <div class="text-center">
          <span class="section__label">Our Programs</span>
          <h2 class="section__title">Explore Our Courses</h2>
          <p class="section__subtitle">Comprehensive Quranic education programs designed for all ages and skill levels</p>
        </div>

        <div class="courses-grid">
          <article class="course-card fade-in" id="course-noorani">
            <div class="course-card__image">
              <img src="/images/Course_pic/noorani_qaida_english.jpeg" alt="Noorani Qaida Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Noorani Qaida Course</h3>
              <p class="course-card__text">Our foundational course perfect for beginners of all ages. Dive into the basics of Quranic learning with structured lessons and expert guidance.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="course-reading">
            <div class="course-card__image">
              <img src="/images/Course_pic/quran_reading_pic.jpg" alt="Quran Reading Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Quran Reading Course</h3>
              <p class="course-card__text">Learn Arabic script and Tajweed rules effortlessly. Guided by experts and supported by comprehensive resources and instructional materials.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="course-translation">
            <div class="course-card__image">
              <img src="/images/Course_pic/qurantafseer.jpg" alt="Quran Translation Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Quran Translation</h3>
              <p class="course-card__text">Learn Quranic translation with Tafseer Ul Quran and understand the real meaning of the Quran with experienced online tutors.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="course-tajweed">
            <div class="course-card__image">
              <img src="/images/Course_pic/tajweed_quran_pic.jpg" alt="Tajweed Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Quran with Tajweed Course</h3>
              <p class="course-card__text">Refine your Quranic recitation by mastering Tajweed rules. Led by experienced teachers, learn rules like Ghunna, Qalqala, and more.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="course-hifz">
            <div class="course-card__image">
              <img src="/images/Course_pic/quran_memorization.jpeg" alt="Quran Memorization Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Quran Memorization (Hifz)</h3>
              <p class="course-card__text">Join our Online Hifz Program. Expert tutors guide students of all ages through this transformative memorization journey with Tajweed.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="course-surahs">
            <div class="course-card__image">
              <img src="/images/Course_pic/memorization_of_surahs.png" alt="Key Surahs Memorization" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Key Surahs Memorization</h3>
              <p class="course-card__text">Designed for busy learners who want to memorize key surahs like Yaseen, Al Mulk, and more. Learn at your own pace, recite anytime.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Features / Why Us Section -->
    <section class="section" aria-label="Why Choose Us" id="features">
      <div class="container">
        <div class="text-center">
          <span class="section__label">Why Choose Us</span>
          <h2 class="section__title">What Makes Us Special</h2>
          <p class="section__subtitle">Experience the difference with our unique approach to online Quranic education</p>
        </div>

        <div class="features-grid">
          <div class="feature-card fade-in">
            <div class="feature-card__icon">
              <img src="/images/Feature_pic/desired_timing_logo.png" alt="" aria-hidden="true" width="40" height="40">
            </div>
            <h3 class="feature-card__title">Flexible Timing</h3>
            <p class="feature-card__text">Customize your learning schedule to fit your lifestyle. Simply let us know your preferred timings, and we'll tailor classes accordingly.</p>
          </div>

          <div class="feature-card fade-in">
            <div class="feature-card__icon">
              <img src="/images/pics/girl.png" alt="" aria-hidden="true" width="40" height="40">
            </div>
            <h3 class="feature-card__title">Female Teachers</h3>
            <p class="feature-card__text">Highly qualified female Quran tutors available for children and female students, ensuring a comfortable and supportive environment.</p>
          </div>

          <div class="feature-card fade-in">
            <div class="feature-card__icon">
              <img src="/images/Feature_pic/any_device_logo.png" alt="" aria-hidden="true" width="40" height="40">
            </div>
            <h3 class="feature-card__title">Any Device, Anywhere</h3>
            <p class="feature-card__text">Use Zoom, MS Teams, or Google Meet on any device — computer, smartphone, or tablet. Take classes from anywhere in the world.</p>
          </div>

          <div class="feature-card fade-in">
            <div class="feature-card__icon">
              <img src="/images/Feature_pic/indivisual_session_logo.png" alt="" aria-hidden="true" width="40" height="40">
            </div>
            <h3 class="feature-card__title">Individual Sessions</h3>
            <p class="feature-card__text">Every student receives dedicated one-on-one attention. No large groups — just personalized learning for maximum progress.</p>
          </div>

          <div class="feature-card fade-in">
            <div class="feature-card__icon">
              <img src="/images/Feature_pic/staff_logo.png" alt="" aria-hidden="true" width="40" height="40">
            </div>
            <h3 class="feature-card__title">Qualified Staff</h3>
            <p class="feature-card__text">Our certified tutors with expertise in Islamic principles provide dynamic, engaging learning experiences for all students.</p>
          </div>

          <div class="feature-card fade-in">
            <div class="feature-card__icon">
              <img src="/images/Feature_pic/affordable_fee_logo .png" alt="" aria-hidden="true" width="40" height="40">
            </div>
            <h3 class="feature-card__title">Affordable Fees</h3>
            <p class="feature-card__text">Quality education at affordable prices, with family discounts for siblings and flexible payment options for everyone.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="section" aria-label="Start Learning">
      <div class="container">
        <div class="cta-banner fade-in">
          <h2 class="cta-banner__title">Start Your Quranic Journey Today</h2>
          <p class="cta-banner__text">Experience our online Quran courses with a complimentary 3-day trial. No obligations — dive in and see the difference.</p>
          <a href="/register" class="btn btn--accent btn--lg">Register for Free Trial</a>
        </div>
      </div>
    </section>

    <!-- Trial Registration Form -->
    <section class="section section--alt" aria-label="Free Trial Registration" id="trial-form">
      <div class="container container--narrow">
        <div class="trial-form fade-in">
          <h2 class="trial-form__title">Register for Free 3-Day Trial</h2>
          <p class="trial-form__subtitle">Fill out the form below and our team will contact you to schedule your free lessons.</p>

          <form id="trial-registration-form" class="form-grid" novalidate>
            <div class="form-group">
              <label class="form-label" for="trial-name">Name *</label>
              <input class="form-input" type="text" id="trial-name" name="name" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="trial-gender">Gender *</label>
              <select class="form-select" id="trial-gender" name="gender" required>
                <option value="">Select Gender</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="trial-age">Age</label>
              <input class="form-input" type="number" id="trial-age" name="age" min="3" max="120">
            </div>
            <div class="form-group">
              <label class="form-label" for="trial-course">Course *</label>
              <select class="form-select" id="trial-course" name="course" required>
                <option value="">Select Course</option>
                <option value="Online Noorani Qaida Course">Noorani Qaida</option>
                <option value="Online Quran Reading Course">Quran Reading</option>
                <option value="Online Quran Translation Course">Quran Translation</option>
                <option value="Online Quran with Tajweed Course">Quran with Tajweed</option>
                <option value="Online Quran Memorization (HIFZ) Course">Quran Memorization (Hifz)</option>
                <option value="Memorization of Key Surahs Online Course">Key Surahs Memorization</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="trial-phone">Phone *</label>
              <input class="form-input" type="tel" id="trial-phone" name="phone" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="trial-country">Country *</label>
              <input class="form-input" type="text" id="trial-country" name="country" required>
            </div>
            <div class="form-group form-group--full">
              <label class="form-label" for="trial-email">Email *</label>
              <input class="form-input" type="email" id="trial-email" name="email" required>
            </div>
            <div class="form-submit">
              <button type="submit" class="btn btn--primary btn--lg" style="width:100%">Submit Registration</button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
