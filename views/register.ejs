<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="page-header__title">Register Now</h1>
        <p class="page-header__breadcrumb"><a href="/">Home</a> / Register</p>
      </div>
    </section>

    <section class="section" aria-label="Registration Form">
      <div class="container container--narrow">
        <div class="text-center" style="margin-bottom: var(--space-8);">
          <span class="section__label">Get Started</span>
          <h2 class="section__title">Student Registration</h2>
          <p class="section__subtitle">Fill out the form below with your details. Our team will contact you to schedule your free trial lessons and provide all information.</p>
        </div>

        <div class="trial-form fade-in">
          <form id="registration-form" class="form-grid" novalidate>
            <div class="form-group">
              <label class="form-label" for="reg-name">Name *</label>
              <input class="form-input" type="text" id="reg-name" name="name" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-guardian">Guardian / Father Name</label>
              <input class="form-input" type="text" id="reg-guardian" name="guardianName">
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-gender">Gender *</label>
              <select class="form-select" id="reg-gender" name="gender" required>
                <option value="">Select Gender</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-age">Age</label>
              <input class="form-input" type="number" id="reg-age" name="age" min="3" max="120">
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-course">Course *</label>
              <select class="form-select" id="reg-course" name="course" required>
                <option value="">Select Course</option>
                <option value="Online Noorani Qaida Course">Noorani Qaida</option>
                <option value="Online Quran Reading Course">Quran Reading</option>
                <option value="Online Quran Translation Course">Quran Translation</option>
                <option value="Online Quran with Tajweed Course">Quran with Tajweed</option>
                <option value="Online Quran Memorization (HIFZ) Course">Quran Memorization (Hifz)</option>
                <option value="Memorization of Key Surahs Online Course">Key Surahs Memorization</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-phone">Phone *</label>
              <input class="form-input" type="tel" id="reg-phone" name="phone" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-country">Country *</label>
              <input class="form-input" type="text" id="reg-country" name="country" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="reg-email">Email *</label>
              <input class="form-input" type="email" id="reg-email" name="email" required>
            </div>
            <div class="form-group form-group--full">
              <label class="form-label" for="reg-message">Any Message</label>
              <textarea class="form-textarea" id="reg-message" name="message" rows="4"></textarea>
            </div>
            <div class="form-submit">
              <button type="submit" class="btn btn--primary btn--lg" style="width:100%">Submit Registration</button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
