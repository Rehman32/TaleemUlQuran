<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/header') %>

  <main>
    <section class="page-header">
      <div class="container">
        <h1 class="page-header__title">Our Courses</h1>
        <p class="page-header__breadcrumb"><a href="/">Home</a> / Courses</p>
      </div>
    </section>

    <section class="section" aria-label="All Courses">
      <div class="container">
        <div class="text-center">
          <span class="section__label">What We Offer</span>
          <h2 class="section__title">Comprehensive Quranic Programs</h2>
          <p class="section__subtitle">Programs designed for learners of all ages — from beginners to advanced, taught by expert tutors worldwide.</p>
        </div>

        <div class="courses-grid">
          <article class="course-card fade-in" id="noorani-qaida">
            <div class="course-card__image">
              <img src="/images/Course_pic/noorani_qaida_english.jpeg" alt="Noorani Qaida Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Noorani Qaida Course</h3>
              <p class="course-card__text">Our foundational Noorani Qaida Course is perfect for beginners of all ages. Dive into the basics of Quranic learning with structured lessons and expert guidance. Start your journey in mastering Quranic recitation today.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="quran-reading">
            <div class="course-card__image">
              <img src="/images/Course_pic/quran_reading_pic.jpg" alt="Quran Reading Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Quran Reading Course</h3>
              <p class="course-card__text">Explore our Online Quran Reading Course, tailored for all ages. Learn Arabic script and Tajweed rules effortlessly with our interactive curriculum, guided by experts and supported by comprehensive resources.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="quran-translation">
            <div class="course-card__image">
              <img src="/images/Course_pic/qurantafseer.jpg" alt="Quran Translation & Tafseer Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Quran Translation Course</h3>
              <p class="course-card__text">Learn Quranic translation with Tafseer Ul Quran and understand the real meaning of the Quran with experienced online tutors. Focus on meanings and progress seamlessly towards mastery.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="tajweed">
            <div class="course-card__image">
              <img src="/images/Course_pic/tajweed_quran_pic.jpg" alt="Tajweed Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Online Quran with Tajweed Course</h3>
              <p class="course-card__text">Refine your Quranic recitation with our Tajweed Course. Perfect for those who've completed basic Quran reading. Learn and apply rules like Ghunna, Qalqala, and more with experienced teachers.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="hifz">
            <div class="course-card__image">
              <img src="/images/Course_pic/quran_memorization.jpeg" alt="Quran Memorization (Hifz) Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Quran Memorization (Hifz) Course</h3>
              <p class="course-card__text">Join our Online Hifz Program for Quran memorization. Suitable for all ages, our expert tutors guide students through this transformative journey with dedicated instruction and Tajweed.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>

          <article class="course-card fade-in" id="key-surahs">
            <div class="course-card__image">
              <img src="/images/Course_pic/memorization_of_surahs.png" alt="Key Surahs Memorization Course" width="400" height="200" loading="lazy">
            </div>
            <div class="course-card__body">
              <h3 class="course-card__title">Memorization of Key Surahs</h3>
              <p class="course-card__text">Designed for busy learners who desire to memorize key surahs from the Quran — including Yaseen, Al Mulk, and more. Experience the convenience of reciting anytime, anywhere.</p>
              <div class="course-card__actions">
                <a href="/pricing" class="btn btn--outline">Details</a>
                <a href="/register" class="btn btn--primary">Register Free</a>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section section--alt" aria-label="Call to Action">
      <div class="container">
        <div class="cta-banner fade-in">
          <h2 class="cta-banner__title">Ready to Begin Your Journey?</h2>
          <p class="cta-banner__text">Start with a free 3-day trial — no obligations. Experience the quality of our teaching firsthand.</p>
          <a href="/register" class="btn btn--accent btn--lg">Register for Free Trial</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
